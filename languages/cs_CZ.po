msgid "Did you enjoy this article? Send some sats ⚡"
msgstr "Líbil se ti článek? Pošli satoshi ⚡"

msgid "No wallet? Download one here"
msgstr "Nemáš peněženku? Stáhni si zde"

msgid "Choose amount"
msgstr "Zvol částku"

msgid "Click \"Send via Lightning\""
msgstr "Klikni na „Poslat přes Lightning“"

msgid "custom"
msgstr "vlastní"

msgid "Enter amount in sats"
msgstr "Zadej částku v sats"

msgid "Send via Lightning"
msgstr "Poslat přes Lightning"

msgid "Loading…"
msgstr "Načítám…"

msgid "Scan QR with your mobile Lightning wallet"
msgstr "Naskenuj QR mobilní Lightning peněženkou"

msgid "Click to copy"
msgstr "Klikni pro zkopírování"

msgid "or send directly to:"
msgstr "nebo pošli přímo na:"

msgid "BVK Lightning Donate – Settings"
msgstr "BVK Lightning Donate – Nastavení"

msgid "BVK Lightning Donate"
msgstr "BVK Lightning Donate"

msgid "You do not have permission to view this page."
msgstr "Nemáš oprávnění k zobrazení této stránky."

msgid "Invalid Lightning address format. Expected format: user@domain.com"
msgstr "Neplatný formát Lightning adresy. Očekáván formát uživatel@domena.cz"

msgid "Enter at least one valid amount (positive number)."
msgstr "Zadej alespoň jednu platnou částku (kladné číslo)."

msgid "Widget active"
msgstr "Widget aktivní"

msgid "Show widget on the site"
msgstr "Zobrazovat widget na webu"

msgid "Disabled until you configure the plugin. Check this to start showing the widget according to the settings below."
msgstr "Vypnuto dokud plugin nenakonfiguruješ. Po zaškrtnutí se widget začne zobrazovat podle nastavení níže."

msgid "Lightning address"
msgstr "Lightning adresa"

msgid "Format: user@wallet.com. What is %s?"
msgstr "Formát: uživatel@peněženka.cz. Co je %s?"

msgid "Preset amounts (sats)"
msgstr "Přednastavené částky (sats)"

msgid "Comma-separated, e.g. 1000,5000,21000"
msgstr "Oddělené čárkou, např. 1000,5000,21000"

msgid "Widget title"
msgstr "Nadpis widgetu"

msgid "Subtitle"
msgstr "Podtitulek"

msgid "Display below"
msgstr "Zobrazit pod"

msgid "Content type below which the widget will be automatically added."
msgstr "Typ obsahu, pod který se widget automaticky přidá."

msgid "Primary color"
msgstr "Primární barva"

msgid "Widget background"
msgstr "Pozadí widgetu"

msgid "Wallet link – text"
msgstr "Odkaz na peněženku – text"

msgid "Wallet link – URL"
msgstr "Odkaz na peněženku – URL"

msgid "Leave empty to hide the link."
msgstr "Nech prázdné pro skrytí odkazu."

msgid "How it works"
msgstr "Jak to funguje"

msgid "The widget is automatically displayed below the selected content types. For manual placement, use the shortcode:"
msgstr "Widget se automaticky zobrazí pod obsahem vybraných typů článků. Pro ruční umístění použij shortcode:"

msgid "If the shortcode is used in a post, automatic insertion will be disabled for that post."
msgstr "Pokud je shortcode použitý v článku, automatické vložení se pro tento článek vypne."

msgid "Copied!"
msgstr "Zkopírováno"

msgid "Copy failed"
msgstr "Kopírování se nezdařilo"

msgid "Could not load payment details. Copy the Lightning address and send manually."
msgstr "Nepodařilo se načíst platební údaje. Zkopíruj Lightning adresu a pošli ručně."

msgid "Enter a valid amount in sats"
msgstr "Zadej platnou částku v sats"

msgid "Amount is outside the wallet's allowed range"
msgstr "Částka je mimo povolený rozsah peněženky"
